    "@prisma/client": "^7",
    "bcryptjs": "^3.0.3",
    "cross-env": "^10",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "prisma": "^7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4",
    "socket.io-client": "^4",
    "tsx": "^4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10",
